{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fx.rosuh.me/schema/manifest.schema.json",
  "title": "FX Lab fx-index.json manifest",
  "type": "object",
  "required": ["name", "version", "homepage", "sections", "effects"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "homepage": { "type": "string", "minLength": 1 },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "nameLocal": { "type": ["string", "null"] }
        }
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "name", "section", "url"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+$" },
          "kind": { "type": "string", "enum": ["shader", "canvas", "dom"] },
          "name": { "type": "string" },
          "section": { "type": "string" },
          "url": { "type": "string" },
          "preview": { "type": ["string", "null"] }
        }
      }
    }
  }
}
